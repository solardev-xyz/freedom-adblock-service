{
  "name": "freedom-adblock-service",
  "version": "0.1.0",
  "description": "Builds Safari/WebKit content-blocker JSON for Freedom Browser iOS from EasyList-family filter lists.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx bin/build.ts",
    "typecheck": "tsc --noEmit",
    "publish:swarm": "tsx bin/publish.ts",
    "serve:swarm": "tsx bin/serve.ts",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@ethersphere/bee-js": "^12.2.1",
    "adblock-rs": "0.12.3",
    "ethers": "^6.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
